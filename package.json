{
  "name": "world-cup-2026-tournament-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node server.mjs",
    "web:dev": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "web:start": "npm run start --workspace apps/web",
    "db:seed:generate": "node scripts/generate-supabase-seed.mjs",
    "ingestion:test": "npm run test --workspace apps/ingestion-worker",
    "ingestion:dry-run": "npm run dry-run --workspace apps/ingestion-worker",
    "ingestion:mapping-dry-run": "npm run mapping-dry-run --workspace apps/ingestion-worker",
    "ingestion:import-mappings": "npm run import-mappings --workspace apps/ingestion-worker --",
    "ingestion:discover-mappings": "npm run discover-mappings --workspace apps/ingestion-worker --",
    "ingestion:fetch-api-football-fixtures": "npm run fetch-api-football-fixtures --workspace apps/ingestion-worker --",
    "ingestion:fetch-sportmonks-fixtures": "npm run fetch-sportmonks-fixtures --workspace apps/ingestion-worker --",
    "ingestion:sync-api-football-live": "npm run sync-api-football-live --workspace apps/ingestion-worker --",
    "ingestion:fetch-espn-fixtures": "npm run fetch-espn-fixtures --workspace apps/ingestion-worker --",
    "ingestion:sync-espn-live": "npm run sync-espn-live --workspace apps/ingestion-worker --",
    "secret:scan": "bash scripts/secret-scan.sh",
    "test": "node --test",
    "check": "node --check src/**/*.js"
  }
}
