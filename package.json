{
  "name": "world-cup-2026-tournament-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node server.mjs",
    "web:dev": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "web:start": "npm run start --workspace apps/web",
    "test": "node --test",
    "check": "node --check src/**/*.js"
  }
}
